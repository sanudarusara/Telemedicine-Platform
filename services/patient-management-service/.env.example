# Example environment variables — copy to .env and fill values for local development

# Patient service uses its own database (patient-management)
MONGO_URI=mongodb://localhost:27017/patient-management
KAFKA_BROKER=127.0.0.1:9092
PORT=5001

# Gateway Security (must match INTERNAL_API_KEY in api-gateway)
INTERNAL_API_KEY=gateway-secret-key-change-in-production
