# ══════════════════════════════════════════════════════════════════════════════
# Auth Service — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in values for local development.

# Service port
PORT=5000

# ── Database ───────────────────────────────────────────────────────────────────
# Auth service owns its own database (auth-management)
MONGO_URI=mongodb://localhost:27017/auth-management

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST match JWT_SECRET in api-gateway so the gateway can verify tokens
JWT_SECRET=your_shared_jwt_secret_here_use_same_across_all_services
JWT_EXPIRES_IN=7d

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092

# ── Security ──────────────────────────────────────────────────────────────────
# Shared internal API key — must match INTERNAL_API_KEY in api-gateway
INTERNAL_API_KEY=gateway-secret-key-change-in-production
