# ══════════════════════════════════════════════════════════════════════════════
# Audit Management Service — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# IMPORTANT: Copy this file to .env and fill in actual values for local development

# ── Gateway Security ───────────────────────────────────────────────────────────
# CRITICAL: This service must ONLY be accessible through the API Gateway
# The INTERNAL_API_KEY validates that requests came from the gateway
INTERNAL_API_KEY=gateway-secret-key-change-in-production

# ── MongoDB Configuration ──────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/audit_db

# ── Kafka Configuration ────────────────────────────────────────────────────────
KAFKA_BROKER=127.0.0.1:9092
KAFKA_CLIENT_ID=audit-management-service
KAFKA_GROUP_ID=audit-service-group

# ── External Services ──────────────────────────────────────────────────────────
# URL of the Patient Management Service used to fetch user role if not included
# in Kafka events (fallback mechanism)
PATIENT_SERVICE_URL=http://localhost:5001

# ── Server Configuration ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
