PORT=3001
NODE_ENV=development

# MongoDB - Local development
## Replace with your secure environment variables in production.
MONGODB_URI=mongodb://localhost:27017/appointment-service

# Service URLs (for local development)
# Patient management service (default port 5001)
PATIENT_SERVICE_URL=http://localhost:5001
# Doctor service (if present)
DOCTOR_SERVICE_URL=http://localhost:5006
# Notification service (default in this repo listens on 3002)
NOTIFICATION_SERVICE_URL=http://localhost:3002

# Docker flag
DOCKER_ENV=false
 
# Optional: token used for internal service-to-service auth when calling other APIs
# INTERNAL_API_TOKEN=some-internal-token
