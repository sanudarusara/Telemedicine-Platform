# ══════════════════════════════════════════════════════════════════════════════
# API Gateway — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# The gateway is now stateless — no MongoDB or Kafka connection needed.
# It only verifies JWT signatures and proxies to downstream services.

# ── JWT ────────────────────────────────────────────────────────────────────────
# MUST match JWT_SECRET in auth-service so the gateway can verify tokens
JWT_SECRET=your_shared_jwt_secret_here_use_same_across_all_services

# ── Microservice URLs ──────────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:5000
PATIENT_SERVICE_URL=http://localhost:5001
AUDIT_SERVICE_URL=http://localhost:5002
NOTIFICATION_SERVICE_URL=http://localhost:5003
PAYMENT_SERVICE_URL=http://localhost:5004
AI_SYMPTOM_SERVICE_URL=http://localhost:5005

# ── Security ───────────────────────────────────────────────────────────────────
# Internal API key injected into every request forwarded to a downstream service
INTERNAL_API_KEY=gateway-secret-key-change-in-production

# ── Gateway Configuration ──────────────────────────────────────────────────────
PORT=5400
NODE_ENV=development
